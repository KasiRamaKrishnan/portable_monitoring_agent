global:
  scrape_interval: 15s

scrape_configs:
  - job_name: 'monitor_node'
    static_configs:
      - targets:
          - '{{ monitor_ip }}:9100'

  - job_name: 'worker_nodes'
    static_configs:
      - targets:
{% for ip in worker_ips %}
          - '{{ ip }}:9100'
{% endfor %}
