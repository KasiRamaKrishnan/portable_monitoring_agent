global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  # ─── Linux: Monitor Node ──────────────────────────────────────────────────
  - job_name: 'monitor_node'
    static_configs:
      - targets:
          - '{{ monitor_ip }}:9100'
        labels:
          platform: linux
          role: monitor

  # ─── Linux: Worker Nodes ──────────────────────────────────────────────────
  - job_name: 'linux_worker_nodes'
    static_configs:
      - targets:
{% for ip in worker_ips %}
          - '{{ ip }}:9100'
{% endfor %}
        labels:
          platform: linux
          role: worker

  # ─── Windows: Worker Nodes ────────────────────────────────────────────────
  # Windows Exporter runs on port 9182 (vs 9100 for Node Exporter)
{% if windows_worker_ips is defined and windows_worker_ips | length > 0 %}
  - job_name: 'windows_worker_nodes'
    static_configs:
      - targets:
{% for ip in windows_worker_ips %}
          - '{{ ip }}:9182'
{% endfor %}
        labels:
          platform: windows
          role: worker
{% endif %}

  # ─── Kubernetes: API Server ───────────────────────────────────────────────
{% if kubernetes_enabled is defined and kubernetes_enabled %}
  - job_name: 'kubernetes-apiservers'
    kubernetes_sd_configs:
      - role: endpoints
        api_server: '{{ k8s_api_server | default("https://kubernetes.default.svc") }}'
        tls_config:
          ca_file: /var/run/secrets/kubernetes.io/serviceaccount/ca.crt
        bearer_token_file: /var/run/secrets/kubernetes.io/serviceaccount/token
    scheme: https
    tls_config:
      ca_file: /var/run/secrets/kubernetes.io/serviceaccount/ca.crt
    bearer_token_file: /var/run/secrets/kubernetes.io/serviceaccount/token
    relabel_configs:
      - source_labels: [__meta_kubernetes_namespace, __meta_kubernetes_service_name, __meta_kubernetes_endpoint_port_name]
        action: keep
        regex: default;kubernetes;https

  # ─── Kubernetes: Nodes (kubelet) ──────────────────────────────────────────
  - job_name: 'kubernetes-nodes'
    kubernetes_sd_configs:
      - role: node
        api_server: '{{ k8s_api_server | default("https://kubernetes.default.svc") }}'
        tls_config:
          ca_file: /var/run/secrets/kubernetes.io/serviceaccount/ca.crt
        bearer_token_file: /var/run/secrets/kubernetes.io/serviceaccount/token
    scheme: https
    tls_config:
      ca_file: /var/run/secrets/kubernetes.io/serviceaccount/ca.crt
    bearer_token_file: /var/run/secrets/kubernetes.io/serviceaccount/token
    relabel_configs:
      - action: labelmap
        regex: __meta_kubernetes_node_label_(.+)

  # ─── Kubernetes: Node Exporter DaemonSet ─────────────────────────────────
  - job_name: 'kubernetes-node-exporter'
    kubernetes_sd_configs:
      - role: endpoints
        namespaces:
          names: ['monitoring']
    relabel_configs:
      - source_labels: [__meta_kubernetes_service_name]
        action: keep
        regex: node-exporter
      - source_labels: [__meta_kubernetes_endpoint_node_name]
        target_label: node
      - action: labelmap
        regex: __meta_kubernetes_node_label_(.+)

  # ─── Kubernetes: kube-state-metrics ──────────────────────────────────────
  - job_name: 'kube-state-metrics'
    kubernetes_sd_configs:
      - role: endpoints
        namespaces:
          names: ['monitoring']
    relabel_configs:
      - source_labels: [__meta_kubernetes_service_name]
        action: keep
        regex: kube-state-metrics

  # ─── Kubernetes: cAdvisor (container metrics via kubelet) ─────────────────
  - job_name: 'kubernetes-cadvisor'
    kubernetes_sd_configs:
      - role: node
        api_server: '{{ k8s_api_server | default("https://kubernetes.default.svc") }}'
        tls_config:
          ca_file: /var/run/secrets/kubernetes.io/serviceaccount/ca.crt
        bearer_token_file: /var/run/secrets/kubernetes.io/serviceaccount/token
    scheme: https
    metrics_path: /metrics/cadvisor
    tls_config:
      ca_file: /var/run/secrets/kubernetes.io/serviceaccount/ca.crt
    bearer_token_file: /var/run/secrets/kubernetes.io/serviceaccount/token
    relabel_configs:
      - action: labelmap
        regex: __meta_kubernetes_node_label_(.+)
      - target_label: __address__
        replacement: '{{ k8s_api_server | default("kubernetes.default.svc:443") }}'
      - source_labels: [__meta_kubernetes_node_name]
        regex: (.+)
        target_label: __metrics_path__
        replacement: /api/v1/nodes/${1}/proxy/metrics/cadvisor

  # ─── Kubernetes: Pods with prometheus.io/scrape annotation ───────────────
  - job_name: 'kubernetes-pods'
    kubernetes_sd_configs:
      - role: pod
        namespaces:
          names: []  # empty = all namespaces
    relabel_configs:
      - source_labels: [__meta_kubernetes_pod_annotation_prometheus_io_scrape]
        action: keep
        regex: "true"
      - source_labels: [__meta_kubernetes_pod_annotation_prometheus_io_path]
        action: replace
        target_label: __metrics_path__
        regex: (.+)
      - source_labels: [__address__, __meta_kubernetes_pod_annotation_prometheus_io_port]
        action: replace
        regex: ([^:]+)(?::\d+)?;(\d+)
        replacement: $1:$2
        target_label: __address__
      - action: labelmap
        regex: __meta_kubernetes_pod_label_(.+)
      - source_labels: [__meta_kubernetes_namespace]
        target_label: namespace
      - source_labels: [__meta_kubernetes_pod_name]
        target_label: pod
{% endif %}
