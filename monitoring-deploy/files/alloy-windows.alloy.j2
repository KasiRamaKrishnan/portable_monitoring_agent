// =============================================================================
// Grafana Alloy — Windows Agent Configuration
// Replaces: Windows Exporter (metrics) + Promtail for Windows (logs)
//
// This single agent:
//   1. Collects all Windows system metrics (CPU, memory, disk, network, etc.)
//   2. Collects Windows Event Logs (Application, System, Security)
//   3. PUSHES everything to the central monitor server via remote_write
//
// Generated by Ansible from alloy-windows.alloy.j2
// Monitor server: {{ monitor_ip }}
// =============================================================================

// ─── Windows System Metrics (replaces Windows Exporter) ──────────────────────
// Collects: CPU, memory, disk I/O, disk space, network, services, processes,
// OS info, system stats — same metrics as windows_exporter.
prometheus.exporter.windows "system" {
  enabled_collectors = [
    "cpu",
    "cs",
    "logical_disk",
    "memory",
    "net",
    "os",
    "process",
    "service",
    "system",
    "textfile",
  ]
}

prometheus.scrape "windows_metrics" {
  targets         = prometheus.exporter.windows.system.targets
  forward_to      = [prometheus.remote_write.monitor.receiver]
  scrape_interval = "15s"
  scrape_timeout  = "10s"
}

// ─── Push Metrics to Prometheus ───────────────────────────────────────────────
prometheus.remote_write "monitor" {
  endpoint {
    url = "http://{{ monitor_ip }}:9090/api/v1/write"

    queue_config {
      capacity             = 10000
      max_shards           = 50
      max_samples_per_send = 2000
      batch_send_deadline  = "5s"
    }
  }

  // Labels added to every metric from this host
  external_labels = {
    hostname = env("COMPUTERNAME"),
    platform = "windows",
  }
}

// ─── Windows Application Event Log ────────────────────────────────────────────
loki.source.windowsevent "application" {
  eventlog_name          = "Application"
  use_incoming_timestamp = true
  forward_to             = [loki.write.monitor.receiver]
  labels = {
    job      = "windows_events",
    log_type = "application",
    hostname = env("COMPUTERNAME"),
    platform = "windows",
  }
}

// ─── Windows System Event Log ─────────────────────────────────────────────────
loki.source.windowsevent "system" {
  eventlog_name          = "System"
  use_incoming_timestamp = true
  forward_to             = [loki.write.monitor.receiver]
  labels = {
    job      = "windows_events",
    log_type = "system",
    hostname = env("COMPUTERNAME"),
    platform = "windows",
  }
}

// ─── Windows Security Event Log (errors and warnings only) ───────────────────
loki.source.windowsevent "security" {
  eventlog_name          = "Security"
  use_incoming_timestamp = true
  xpath_query            = "*[System[(Level=1 or Level=2 or Level=3)]]"
  forward_to             = [loki.write.monitor.receiver]
  labels = {
    job      = "windows_events",
    log_type = "security",
    hostname = env("COMPUTERNAME"),
    platform = "windows",
  }
}

// ─── Push Logs to Loki ────────────────────────────────────────────────────────
loki.write "monitor" {
  endpoint {
    url = "http://{{ monitor_ip }}:3100/loki/api/v1/push"
  }
  external_labels = {
    hostname = env("COMPUTERNAME"),
    platform = "windows",
  }
}
