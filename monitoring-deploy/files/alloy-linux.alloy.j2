// =============================================================================
// Grafana Alloy — Linux Agent Configuration
// Replaces: Node Exporter (metrics) + Promtail (logs)
//
// This single agent:
//   1. Collects all Linux system metrics (CPU, memory, disk, network, etc.)
//   2. Collects system logs (/var/log/*.log) and systemd journal
//   3. PUSHES everything to the central monitor server via remote_write
//
// Generated by Ansible from alloy-linux.alloy.j2
// Monitor server: {{ monitor_ip }}
// =============================================================================

// ─── Linux System Metrics (replaces Node Exporter) ────────────────────────────
// Exposes the same metrics as Node Exporter — no separate binary needed.
prometheus.exporter.unix "system" {
  // Collectors enabled by default: cpu, diskstats, filesystem, loadavg,
  // meminfo, netdev, netstat, stat, time, uname, vmstat
  // Disable specific mounts to avoid noisy metrics:
  disable_collectors = ["arp", "bcache", "bonding", "btrfs", "drbd", "edac",
                        "entropy", "fibrechannel", "hwmon", "infiniband",
                        "ipvs", "mdadm", "nfs", "nfsd", "powersupplyclass",
                        "rapl", "schedstat", "selinux", "sockstat",
                        "softnet", "thermal_zone", "zfs"]
}

prometheus.scrape "linux_metrics" {
  targets         = prometheus.exporter.unix.system.targets
  forward_to      = [prometheus.remote_write.monitor.receiver]
  scrape_interval = "15s"
  scrape_timeout  = "10s"
}

// ─── Push Metrics to Prometheus ───────────────────────────────────────────────
// Prometheus on the monitor server must be started with
// --web.enable-remote-write-receiver (already set in docker-compose.yml)
prometheus.remote_write "monitor" {
  endpoint {
    url = "http://{{ monitor_ip }}:9090/api/v1/write"

    queue_config {
      capacity             = 10000
      max_shards           = 50
      max_samples_per_send = 2000
      batch_send_deadline  = "5s"
    }
  }

  // Labels added to every metric from this host
  external_labels = {
    hostname = env("HOSTNAME"),
    platform = "linux",
  }
}

// ─── System Log Files (replaces Promtail /var/log scraping) ──────────────────
local.file_match "system_logs" {
  path_targets = [
    {
      __path__ = "/var/log/syslog",
      job      = "syslog",
      hostname = env("HOSTNAME"),
      platform = "linux",
    },
    {
      __path__ = "/var/log/auth.log",
      job      = "auth",
      hostname = env("HOSTNAME"),
      platform = "linux",
    },
    {
      __path__ = "/var/log/*.log",
      job      = "system_logs",
      hostname = env("HOSTNAME"),
      platform = "linux",
    },
  ]
}

loki.source.file "system_logs" {
  targets    = local.file_match.system_logs.targets
  forward_to = [loki.write.monitor.receiver]
}

// ─── systemd Journal (replaces Promtail journal scraping) ────────────────────
loki.source.journal "systemd" {
  forward_to    = [loki.write.monitor.receiver]
  max_age       = "12h"
  relabels {
    source_labels = ["__journal__systemd_unit"]
    target_label  = "unit"
  }
  relabels {
    source_labels = ["__journal__hostname"]
    target_label  = "hostname"
  }
  relabels {
    source_labels = ["__journal_priority_keyword"]
    target_label  = "level"
  }
  labels = {
    job      = "systemd_journal",
    platform = "linux",
    hostname = env("HOSTNAME"),
  }
}

// ─── Push Logs to Loki ────────────────────────────────────────────────────────
loki.write "monitor" {
  endpoint {
    url = "http://{{ monitor_ip }}:3100/loki/api/v1/push"
  }
  external_labels = {
    hostname = env("HOSTNAME"),
    platform = "linux",
  }
}
