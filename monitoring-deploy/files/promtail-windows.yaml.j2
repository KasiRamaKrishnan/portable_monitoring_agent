server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: C:\monitoring\promtail-data\positions.yaml

clients:
  - url: 'http://{{ monitor_ip }}:3100/loki/api/v1/push'

scrape_configs:
  # Windows System Event Logs
  - job_name: windows_events
    windows_events:
      use_incoming_timestamp: true
      bookmark_path: C:\monitoring\promtail-data\bookmark.xml
      eventlog_name: "Application"
      xpath_query: "*"
      labels:
        job: windows_events
        hostname: '{{ ansible_hostname }}'
        log_type: application
    pipeline_stages:
      - json:
          expressions:
            level: level
            source: source
      - labels:
          level:
          source:

  - job_name: windows_system_events
    windows_events:
      use_incoming_timestamp: true
      bookmark_path: C:\monitoring\promtail-data\bookmark_system.xml
      eventlog_name: "System"
      xpath_query: "*"
      labels:
        job: windows_events
        hostname: '{{ ansible_hostname }}'
        log_type: system
    pipeline_stages:
      - json:
          expressions:
            level: level
            source: source
      - labels:
          level:
          source:

  - job_name: windows_security_events
    windows_events:
      use_incoming_timestamp: true
      bookmark_path: C:\monitoring\promtail-data\bookmark_security.xml
      eventlog_name: "Security"
      xpath_query: "*[System[(Level=1 or Level=2 or Level=3)]]"
      labels:
        job: windows_events
        hostname: '{{ ansible_hostname }}'
        log_type: security

  # Windows IIS Logs (if IIS is installed)
  - job_name: iis_logs
    static_configs:
      - targets:
          - localhost
        labels:
          job: iis
          hostname: '{{ ansible_hostname }}'
          __path__: 'C:\inetpub\logs\LogFiles\W3SVC*\*.log'

  # General Windows application log files
  - job_name: windows_app_logs
    static_configs:
      - targets:
          - localhost
        labels:
          job: windows_applogs
          hostname: '{{ ansible_hostname }}'
          __path__: 'C:\Windows\Logs\**\*.log'
    pipeline_stages:
      - multiline:
          firstline: '^\d{4}-\d{2}-\d{2}'
          max_wait_time: 3s
