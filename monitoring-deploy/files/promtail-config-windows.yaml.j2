server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: C:\Promtail\positions.yaml

clients:
  - url: http://{{ monitor_ip }}:3100/loki/api/v1/push

scrape_configs:
  - job_name: windows_logs
    static_configs:
      - targets:
          - localhost
        labels:
          job: windows
          hostname: "{{ ansible_hostname }}"
          __path__: "C:\\Windows\\System32\\LogFiles\\**\\*.log"
