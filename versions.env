# Grafana Alloy (unified agent — replaces Node Exporter + Windows Exporter + Promtail)
ALLOY_VERSION=1.3.1

# Monitoring backends
PROMETHEUS_VERSION=2.52.0
LOKI_VERSION=2.9.4
ALERTMANAGER_VERSION=0.27.0

# Visualization
GRAFANA_VERSION=10.4.1

# Kubernetes add-ons
KUBE_STATE_METRICS_VERSION=2.12.0
