# ── Terraform state ───────────────────────────────────────────────────────────
# Never commit state files — they contain resource IDs and may contain secrets.
*.tfstate
*.tfstate.*
*.tfstate.backup

# ── Terraform working directory ───────────────────────────────────────────────
.terraform/
.terraform.lock.hcl

# ── Variable files with secrets ───────────────────────────────────────────────
# terraform.tfvars contains passwords and API keys — keep out of git.
terraform.tfvars
*.auto.tfvars

# ── Plan files ────────────────────────────────────────────────────────────────
*.tfplan
*.plan

# ── Crash logs ────────────────────────────────────────────────────────────────
crash.log
crash.*.log

# ── Override files ────────────────────────────────────────────────────────────
override.tf
override.tf.json
*_override.tf
*_override.tf.json
